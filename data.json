<?php
// all.php — Admin panel styled to match index.php
define('DATA_FILE', __DIR__ . '/data.json');
define('HALT_FILE', __DIR__ . '/halt.lock');
function load_data(){ $s=@file_get_contents(DATA_FILE); $arr=$s?json_decode($s,true):[]; return is_array($arr)?$arr:[]; }
$secret_noob='noob'; $secret_super='super'; $ok=false; $advanced=false; $message=''; $msgType='ok';
if($_SERVER['REQUEST_METHOD']==='POST'){
    if(isset($_POST['action'])&&$_POST['action']==='toggle_halt'){ $pass=$_POST['pass']??''; if($pass===$secret_super){
        if(file_exists(HALT_FILE)){@unlink(HALT_FILE);$message='Site successfully unhalted.'; $msgType='ok';}else{file_put_contents(HALT_FILE,'halted');$message='Site halted — uploads are now disabled.'; $msgType='warn';}
        $ok=true;$advanced=true;} else {$message='Unauthorized.'; $msgType='error';}}
    if(isset($_POST['pass'])&&isset($_POST['login'])){ $pass=$_POST['pass']; if($pass===$secret_noob){$ok=true;$advanced=false;}
    elseif($pass===$secret_super){$ok=true;$advanced=true;} else{$message='Incorrect password.'; $msgType='error';} } }
$data=$ok?load_data():[];
$site_halted=file_exists(HALT_FILE);
?>
